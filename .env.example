# ================================
# Configuration BeeSmart Backend
# ================================

# --- Serveur Express ---
PORT=3000
NODE_ENV=development

# --- Anthropic (Claude) ---
# Clé API pour le parsing des observations apicoles via Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI (Whisper) ---
# Clé API pour la transcription audio des messages terrain
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# URL et clé anon de votre projet Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxx

# --- Telegram ---
# Token du bot Telegram (obtenu via @BotFather sur Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# URL publique du serveur pour le webhook Telegram (laisser vide en local = mode polling)
# En production (Railway, Render, Heroku…), mettre l'URL du déploiement
WEBHOOK_URL=https://votre-app.up.railway.app

# --- Paramètres NLP ---
# Taille maximale du fichier audio en Mo (défaut : 25 Mo, limite Whisper)
MAX_AUDIO_SIZE_MB=25
# Langue principale des observations (fr = français)
OBSERVATION_LANGUAGE=fr
